{
  "manifest_version": 3,
  "name": "Smart XPath Generator",
  "version": "1.0.0",
  "description": "Generate smart, stable, human-readable XPath selectors with one click. Avoids dynamic classes, scores reliability, suggests alternatives.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Smart XPath Generator"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "core/dynamic-detector.js",
        "core/xpath-validator.js",
        "core/stability-scorer.js",
        "core/xpath-generator.js",
        "content/highlighter.js",
        "content/overlay.js",
        "content/content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-selector": {
      "suggested_key": {
        "default": "Alt+Shift+X",
        "mac": "Alt+Shift+X"
      },
      "description": "Toggle XPath selector mode"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ]
}
